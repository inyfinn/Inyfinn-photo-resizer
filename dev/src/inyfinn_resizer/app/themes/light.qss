/* Inyfinn Photo Resizer — jasny motyw v2 (czytelny, siatka) */

QMainWindow {
    background-color: #dde4ec;
    color: #152033;
    font-family: "Segoe UI", system-ui, sans-serif;
    font-size: 13px;
}

QWidget#centralRoot, QWidget#settingsBody, QWidget#formatSelector {
    background-color: transparent;
    color: #152033;
}

QLabel {
    background-color: transparent;
    color: #334155;
}

QLabel#appTitle {
    font-size: 16px;
    font-weight: 600;
    color: #0f172a;
}

QLabel#panelTitle {
    font-size: 15px;
    font-weight: 700;
    color: #0f172a;
    padding: 0;
    margin: 0;
    background: transparent;
}

QLabel#sectionTitle {
    font-size: 12px;
    font-weight: 700;
    color: #475569;
    text-transform: none;
    letter-spacing: 0.02em;
    background: transparent;
    padding: 0;
}

QLabel#formLabel, QLabel#formLabelInline {
    color: #475569;
    font-weight: 600;
    background: transparent;
}

QLabel#hintLabel, QLabel#dropHint {
    color: #64748b;
    font-size: 12px;
}

QLabel#queueCount {
    font-size: 14px;
    font-weight: 700;
    color: #0369a1;
}

QLabel#qualityValue {
    font-weight: 700;
    color: #0369a1;
}

QLabel#previewMeta {
    color: #475569;
    font-size: 12px;
    line-height: 1.4;
}

/* —— Panele główne —— */
QFrame#panel, QFrame#dropPanel {
    background-color: #ffffff;
    border: 2px solid #b8c5d6;
    border-radius: 10px;
}

QFrame#dropPanel {
    background-color: #f8fafc;
}

QFrame#sectionBox {
    background-color: #f1f5f9;
    border: 1px solid #cbd5e1;
    border-radius: 8px;
}

QScrollArea#settingsScroll {
    background: transparent;
    border: none;
}

QScrollArea#settingsScroll > QWidget > QWidget {
    background: transparent;
}

/* —— Menu —— */
QMenuBar {
    background-color: #ffffff;
    border-bottom: 1px solid #cbd5e1;
    color: #0f172a;
}

QMenuBar::item:selected {
    background-color: #e0f2fe;
    color: #0369a1;
}

QMenu {
    background-color: #ffffff;
    border: 1px solid #cbd5e1;
    padding: 4px;
}

QMenu::item:selected {
    background-color: #e0f2fe;
    color: #0369a1;
}

/* —— Przyciski (jednolite wymiary) —— */
QPushButton {
    background-color: #ffffff;
    border: 1px solid #94a3b8;
    border-radius: 6px;
    padding: 0 14px;
    min-height: 36px;
    max-height: 36px;
    color: #0f172a;
    font-weight: 500;
}

QPushButton:hover {
    background-color: #f1f5f9;
    border-color: #0284c7;
    color: #0369a1;
}

QPushButton#toolBtn {
    background-color: #ffffff;
    border: 1px solid #cbd5e1;
    min-height: 36px;
    max-height: 36px;
}

QPushButton#toolBtn:hover {
    background-color: #0284c7;
    border-color: #0284c7;
    color: #ffffff;
}

QPushButton#btnSecondary {
    background-color: #ffffff;
    border: 1px solid #94a3b8;
    min-height: 36px;
    max-height: 36px;
    min-width: 120px;
}

QPushButton#primaryBtn {
    background-color: #0284c7;
    color: #ffffff;
    border: 1px solid #0369a1;
    font-weight: 700;
    font-size: 14px;
    min-height: 40px;
    max-height: 40px;
    min-width: 148px;
    border-radius: 6px;
}

QPushButton#primaryBtn:hover {
    background-color: #0369a1;
}

QPushButton#themeToggle {
    background-color: #ede9fe;
    border: 1px solid #a78bfa;
    color: #5b21b6;
    font-weight: 600;
    border-radius: 18px;
    padding: 0 16px;
}

/* —— Lista plików —— */
QTreeWidget#inputList {
    background-color: #ffffff;
    alternate-background-color: #f1f5f9;
    border: 1px solid #cbd5e1;
    border-radius: 6px;
    color: #0f172a;
    outline: none;
}

QTreeWidget#inputList::item {
    padding: 6px 8px;
    min-height: 28px;
}

QTreeWidget#inputList::item:selected {
    background-color: #0284c7;
    color: #ffffff;
}

QTreeWidget#inputList::item:hover:!selected {
    background-color: #e0f2fe;
}

QHeaderView::section {
    background-color: #e2e8f0;
    color: #334155;
    padding: 8px 10px;
    border: none;
    border-bottom: 1px solid #cbd5e1;
    font-weight: 700;
}

/* —— Pola —— */
QComboBox, QLineEdit, QSpinBox {
    background-color: #ffffff;
    border: 1px solid #94a3b8;
    border-radius: 6px;
    padding: 6px 10px;
    min-height: 36px;
    color: #0f172a;
    selection-background-color: #0284c7;
    selection-color: #ffffff;
}

QComboBox:hover, QLineEdit:hover {
    border-color: #0284c7;
}

QComboBox::drop-down {
    border: none;
    width: 28px;
}

QListWidget {
    background-color: #ffffff;
    border: 1px solid #cbd5e1;
    border-radius: 6px;
    color: #0f172a;
}

/* —— Suwak —— */
QSlider::groove:horizontal {
    height: 6px;
    background: #cbd5e1;
    border-radius: 3px;
}

QSlider::handle:horizontal {
    width: 16px;
    height: 16px;
    margin: -5px 0;
    background: #0284c7;
    border: 2px solid #ffffff;
    border-radius: 8px;
}

QSlider::sub-page:horizontal {
    background: #38bdf8;
    border-radius: 3px;
}

QProgressBar {
    border: 1px solid #cbd5e1;
    border-radius: 4px;
    background: #e2e8f0;
    min-height: 12px;
    color: #334155;
}

QProgressBar::chunk {
    background-color: #0284c7;
    border-radius: 3px;
}

/* —— Zakładki —— */
QTabWidget::pane {
    border: none;
    background: transparent;
}

QTabBar::tab {
    background: transparent;
    border-bottom: 2px solid transparent;
    padding: 8px 18px;
    color: #64748b;
    font-weight: 600;
}

QTabBar::tab:selected {
    color: #0369a1;
    border-bottom: 2px solid #0284c7;
}

/* —— Checkboxy —— */
QCheckBox {
    spacing: 8px;
    color: #1e293b;
    min-height: 26px;
    background: transparent;
}

QCheckBox::indicator {
    width: 18px;
    height: 18px;
    border-radius: 4px;
    border: 2px solid #64748b;
    background: #ffffff;
}

QCheckBox::indicator:checked {
    background: #0284c7;
    border-color: #0284c7;
    image: url(@CHECK_ICON@);
}

QLabel#previewBox {
    border: 1px solid #cbd5e1;
    border-radius: 6px;
    background-color: #ffffff;
}

QStatusBar {
    background: #ffffff;
    border-top: 1px solid #cbd5e1;
    color: #64748b;
}

QSplitter::handle {
    background: #cbd5e1;
    width: 3px;
    margin: 4px 2px;
    border-radius: 2px;
}

QSplitter::handle:hover {
    background: #0284c7;
}

/* —— Dialogi —— */
QDialog#appDialog {
    background-color: #ffffff;
    color: #0f172a;
}

QDialog#appDialog QLabel {
    color: #334155;
    background: transparent;
}

QTabWidget#dialogTabs::pane {
    border: 1px solid #cbd5e1;
    border-radius: 6px;
    background: #f8fafc;
    padding: 8px;
}

QTabWidget#dialogTabs QTabBar::tab {
    color: #64748b;
    padding: 6px 14px;
}

QTabWidget#dialogTabs QTabBar::tab:selected {
    color: #0369a1;
    border-bottom: 2px solid #0284c7;
}

QGroupBox#moreOptions {
    border: 1px solid #cbd5e1;
    border-radius: 6px;
    margin-top: 8px;
    padding-top: 8px;
    font-weight: 600;
    color: #334155;
}

QGroupBox#moreOptions::title {
    subcontrol-origin: margin;
    left: 10px;
    padding: 0 6px;
}

/* —— Listy rozwijane (czytelne) —— */
QAbstractItemView {
    background-color: #ffffff;
    color: #0f172a;
    border: 1px solid #94a3b8;
    selection-background-color: #0284c7;
    selection-color: #ffffff;
    outline: none;
}

QListView#formatMultiList::item {
    padding: 6px 10px;
    min-height: 24px;
}

QListView#formatMultiList::item:hover {
    background-color: #e0f2fe;
}

QComboBox#formatMultiCombo {
    min-height: 36px;
}

QComboBox#formatMultiCombo QLineEdit {
    background: #ffffff;
    color: #0f172a;
    border: none;
    padding: 4px 8px;
}

QLabel#hintLabel {
    color: #64748b;
    font-size: 12px;
    background: transparent;
}

QSpinBox {
    background-color: #ffffff;
    border: 1px solid #94a3b8;
    border-radius: 6px;
    padding: 4px 8px;
    min-height: 32px;
    color: #0f172a;
}
