/* Inyfinn Photo Resizer — wspólna struktura UI (identyczna w obu motywach) */

QMainWindow {
    background-color: @BG_WINDOW@;
    color: @FG_TEXT@;
    font-family: "Segoe UI", system-ui, sans-serif;
    font-size: 13px;
}

QWidget#centralRoot, QWidget#settingsBody, QWidget#formatSelector {
    background-color: transparent;
    color: @FG_TEXT@;
}

QLabel {
    background-color: transparent;
    color: @FG_TEXT@;
}

QLabel#appTitle {
    font-size: 16px;
    font-weight: 600;
    color: @FG_TITLE@;
}

QLabel#versionBadge {
    font-size: 11px;
    font-weight: 600;
    color: @FG_ACCENT@;
    background: transparent;
}

QLabel#panelTitle {
    font-size: 13px;
    font-weight: 700;
    color: @FG_TITLE@;
    padding: 0;
    margin: 0;
    background: transparent;
}

QLabel#sectionTitle {
    font-size: 12px;
    font-weight: 700;
    color: @FG_MUTED@;
    background: transparent;
}

QLabel#fieldLabel {
    font-size: 12px;
    font-weight: 600;
    color: @FG_TEXT@;
    background: transparent;
    padding: 0;
    margin: 0;
}

QLabel#advancedSummary {
    font-size: 11px;
    color: @FG_MUTED@;
    padding: 0;
    background: transparent;
    border: none;
}

QLabel#appFooter {
    font-size: 11px;
    font-weight: 600;
    color: @FG_MUTED@;
    padding: 0 4px;
    background: transparent;
}

QDialog#helpGuideDialog {
    background-color: @BG_WINDOW@;
    color: @FG_TEXT@;
}

QLabel#helpGuideIntro {
    font-size: 13px;
    color: @FG_TEXT@;
    background: transparent;
}

QLabel#helpGuideItem {
    font-size: 13px;
    line-height: 1.45;
    color: @FG_TEXT@;
    padding: 2px 0;
    background: transparent;
}

QWidget#helpGuideBody {
    background: transparent;
}

QScrollArea#helpGuideScroll {
    background: transparent;
    border: none;
}

QLabel#helpGuideTitle {
    font-size: 15px;
    font-weight: 700;
    color: @FG_TITLE@;
}

QLabel#helpGuideVersion {
    font-size: 11px;
    font-weight: 600;
    color: @FG_ACCENT@;
}

QLabel#helpGuideContent {
    font-size: 13px;
    color: @FG_TEXT@;
    padding: 4px 2px;
}

QWidget#fieldGroup {
    background: transparent;
}

QLabel#formLabel, QLabel#formLabelInline {
    color: @FG_MUTED@;
    font-weight: 600;
    background: transparent;
}

QLabel#hintLabel, QLabel#dropHint {
    color: @FG_MUTED@;
    font-size: 12px;
}

QLabel#queueCount {
    font-size: 14px;
    font-weight: 700;
    color: @FG_ACCENT@;
}

QLabel#qualityValue {
    font-weight: 700;
    color: @FG_ACCENT@;
}

QLabel#previewMeta {
    color: @FG_MUTED@;
    font-size: 12px;
}

QFrame#panel, QFrame#dropPanel {
    background-color: @BG_PANEL@;
    border: 1px solid @BORDER@;
    border-radius: 8px;
}

QFrame#dropPanel {
    background-color: @BG_PANEL_ALT@;
}

QFrame#sectionBox {
    background-color: @BG_PANEL_ALT@;
    border: 1px solid @BORDER@;
    border-radius: 6px;
}

QFrame#sectionBoxStep1,
QFrame#sectionBoxStep2,
QFrame#sectionBoxStep3 {
    background-color: @BG_PANEL@;
    border: 1px solid @BORDER@;
    border-radius: 10px;
    padding: 0;
}

QFrame#sectionBoxStep1 {
    border-left: 4px solid @S1_BORDER@;
}

QFrame#sectionBoxStep2 {
    border-left: 4px solid @S2_BORDER@;
}

QFrame#sectionBoxStep3 {
    border-left: 4px solid @S3_BORDER@;
}

QLabel#sectionStepTitle {
    font-size: 13px;
    font-weight: 700;
    color: @FG_TITLE@;
    background: transparent;
    padding: 0;
}

QLabel#sectionStepHint {
    font-size: 11px;
    color: @FG_MUTED@;
    background: transparent;
    padding: 0;
    line-height: 1.35;
}

QLabel#workflowHint {
    font-size: 11px;
    color: @FG_MUTED@;
    background: transparent;
    padding: 0 2px 4px 2px;
}

QSlider {
    min-height: 20px;
    padding: 2px 0;
}

QFrame#sectionBoxStep1 QFrame#bgRemoveGroup {
    background-color: @S1_GROUP_BG@;
    border: 1px solid @S1_GROUP_BORDER@;
    border-radius: 6px;
}

QFrame#sectionBoxStep1 QFrame#bgRemoveGroup QCheckBox {
    font-weight: 600;
}

QFrame#sectionBoxStep1 QFrame#bgRemoveGroup QComboBox#bgModelCombo {
    border-color: @S1_CTRL_BORDER@;
    min-width: 110px;
}

/* —— Sekcja 1: Format (fiolet) —— */
QFrame#sectionBoxStep1 {
    background-color: @SECTION1_BG@;
}

QFrame#sectionBoxStep1 QLabel#sectionStepTitle {
    color: @S1_LABEL@;
}

QFrame#sectionBoxStep1 QLabel#fieldLabel {
    color: @S1_LABEL@;
}

QFrame#sectionBoxStep1 QCheckBox::indicator {
    border-color: @S1_CHECK_BORDER@;
}

QFrame#sectionBoxStep1 QCheckBox::indicator:checked {
    background: @S1_CHECK_BG@;
    border-color: @S1_CHECK_BORDER_ON@;
    image: url(@CHECK_S1@);
}

QFrame#sectionBoxStep1 QSlider::groove:horizontal {
    background: @S1_SLIDER_GROOVE@;
}

QFrame#sectionBoxStep1 QSlider::handle:horizontal {
    background: @S1_SLIDER_HANDLE@;
    border-color: @SECTION1_BG@;
}

QFrame#sectionBoxStep1 QSlider::sub-page:horizontal {
    background: @S1_SLIDER_FILL@;
}

QFrame#sectionBoxStep1 QLabel#qualityValue {
    color: @S1_VALUE@;
    font-weight: 700;
}

QFrame#sectionBoxStep1 QComboBox,
QFrame#sectionBoxStep1 QComboBox#formatMultiCombo,
QFrame#sectionBoxStep1 QComboBox#bgModelCombo {
    border-color: @S1_CTRL_BORDER@;
    color: @FG_TEXT@;
}

QFrame#sectionBoxStep1 QComboBox::drop-down {
    border-left-color: @S1_CTRL_BORDER@;
    background: @S1_DROPDOWN_BG@;
}

QFrame#sectionBoxStep1 QComboBox:hover,
QFrame#sectionBoxStep1 QComboBox#formatMultiCombo:hover,
QFrame#sectionBoxStep1 QComboBox#bgModelCombo:hover {
    border-color: @S1_HOVER_BORDER@;
    background-color: @S1_HOVER_BG@;
    color: @FG_TEXT@;
}

QFrame#sectionBoxStep1 QLineEdit:hover,
QFrame#sectionBoxStep1 QSpinBox:hover {
    border-color: @S1_HOVER_BORDER@;
    background-color: @BG_INPUT@;
    color: @FG_TEXT@;
}

QFrame#sectionBoxStep1 QComboBox#formatMultiCombo QLineEdit {
    background: transparent;
    color: @FG_TEXT@;
    border: none;
}

QFrame#sectionBoxStep1 QComboBox#formatMultiCombo:hover QLineEdit,
QFrame#sectionBoxStep1 QComboBox#formatMultiCombo:focus QLineEdit {
    background: transparent;
    color: @FG_TEXT@;
}

QFrame#sectionBoxStep1 QComboBox:focus,
QFrame#sectionBoxStep1 QLineEdit:focus,
QFrame#sectionBoxStep1 QSpinBox:focus {
    border-color: @S1_FOCUS_BORDER@;
}

QFrame#sectionBoxStep1 QComboBox QAbstractItemView::item:selected {
    background-color: @S1_SELECT_BG@;
    color: #ffffff;
}

QFrame#sectionBoxStep1 QLineEdit,
QFrame#sectionBoxStep1 QSpinBox {
    selection-background-color: @S1_SELECT_BG@;
}

QFrame#sectionBoxStep1 QPushButton#btnSecondary {
    border-color: @S1_CTRL_BORDER@;
    color: @S1_BTN_TEXT@;
}

QFrame#sectionBoxStep1 QPushButton#btnSecondary:hover {
    border-color: @S1_HOVER_BORDER@;
    color: @S1_BTN_TEXT@;
    background-color: @S1_HOVER_BG@;
}

/* —— Sekcja 2: Wymiary (teal) —— */
QFrame#sectionBoxStep2 {
    background-color: @SECTION2_BG@;
}

QFrame#sectionBoxStep2 QLabel#sectionStepTitle {
    color: @S2_LABEL@;
}

QFrame#sectionBoxStep2 QLabel#fieldLabel {
    color: @S2_LABEL@;
}

QFrame#sectionBoxStep2 QCheckBox::indicator {
    border-color: @S2_CHECK_BORDER@;
}

QFrame#sectionBoxStep2 QCheckBox::indicator:checked {
    background: @S2_CHECK_BG@;
    border-color: @S2_CHECK_BORDER_ON@;
    image: url(@CHECK_S2@);
}

QFrame#sectionBoxStep2 QSlider::groove:horizontal {
    background: @S2_SLIDER_GROOVE@;
}

QFrame#sectionBoxStep2 QSlider::handle:horizontal {
    background: @S2_SLIDER_HANDLE@;
    border-color: @SECTION2_BG@;
}

QFrame#sectionBoxStep2 QSlider::sub-page:horizontal {
    background: @S2_SLIDER_FILL@;
}

QFrame#sectionBoxStep2 QLabel#qualityValue {
    color: @S2_VALUE@;
    font-weight: 700;
}

QFrame#sectionBoxStep2 QComboBox {
    border-color: @S2_CTRL_BORDER@;
    color: @FG_TEXT@;
}

QFrame#sectionBoxStep2 QComboBox::drop-down {
    border-left-color: @S2_CTRL_BORDER@;
    background: @S2_DROPDOWN_BG@;
}

QFrame#sectionBoxStep2 QComboBox:hover,
QFrame#sectionBoxStep2 QLineEdit:hover,
QFrame#sectionBoxStep2 QLineEdit#minLongestEdit:hover,
QFrame#sectionBoxStep2 QSpinBox:hover {
    border-color: @S2_HOVER_BORDER@;
    background-color: @S2_HOVER_BG@;
    color: @FG_TEXT@;
}

QFrame#sectionBoxStep2 QComboBox:focus,
QFrame#sectionBoxStep2 QLineEdit:focus,
QFrame#sectionBoxStep2 QLineEdit#minLongestEdit:focus,
QFrame#sectionBoxStep2 QSpinBox:focus {
    border-color: @S2_FOCUS_BORDER@;
}

QFrame#sectionBoxStep2 QComboBox QAbstractItemView::item:selected {
    background-color: @S2_SELECT_BG@;
    color: #ffffff;
}

QFrame#sectionBoxStep2 QLineEdit,
QFrame#sectionBoxStep2 QSpinBox {
    selection-background-color: @S2_SELECT_BG@;
}

QFrame#sectionBoxStep2 QPushButton#toolBtn:hover {
    background-color: @S2_TOOL_HOVER@;
    border-color: @S2_TOOL_HOVER@;
    color: #ffffff;
}

/* —— Sekcja 3: Zapis (pomarańcz) —— */
QFrame#sectionBoxStep3 {
    background-color: @SECTION3_BG@;
}

QFrame#sectionBoxStep3 QLabel#sectionStepTitle {
    color: @S3_LABEL@;
}

QFrame#sectionBoxStep3 QLabel#fieldLabel {
    color: @S3_LABEL@;
}

QFrame#sectionBoxStep3 QCheckBox::indicator {
    border-color: @S3_CHECK_BORDER@;
}

QFrame#sectionBoxStep3 QCheckBox::indicator:checked {
    background: @S3_CHECK_BG@;
    border-color: @S3_CHECK_BORDER_ON@;
    image: url(@CHECK_S3@);
}

QFrame#sectionBoxStep3 QLineEdit#outputDirEdit {
    border-color: @S3_INPUT_BORDER@;
    color: @FG_TEXT@;
}

QFrame#sectionBoxStep3 QLineEdit#outputDirEdit:focus,
QFrame#sectionBoxStep3 QLineEdit#outputDirEdit:hover {
    border-color: @S3_INPUT_HOVER_BORDER@;
    background-color: @S3_INPUT_HOVER_BG@;
    color: @FG_TEXT@;
}

QFrame#sectionBoxStep3 QLineEdit#outputDirEdit {
    selection-background-color: @S3_CHECK_BG@;
}

QFrame#sectionBoxStep3 QPushButton#btnUpdatePath {
    background-color: @S3_BTN_PRIMARY@;
    color: #ffffff;
    border: 1px solid @S3_BTN_PRIMARY_BORDER@;
    font-weight: 700;
}

QFrame#sectionBoxStep3 QPushButton#btnUpdatePath:hover {
    background-color: @S3_BTN_PRIMARY_HOVER@;
    border-color: @S3_BTN_PRIMARY_BORDER@;
}

QFrame#sectionBoxStep3 QPushButton#btnUpdatePath:disabled {
    background-color: @BG_PANEL_ALT@;
    color: @FG_MUTED@;
    border-color: @BORDER@;
}

QFrame#sectionBoxStep3 QPushButton#btnBrowse {
    background-color: @BG_INPUT@;
    border: 1px solid @S3_BTN_BROWSE_BORDER@;
    color: @S3_BTN_BROWSE_TEXT@;
    font-weight: 600;
}

QFrame#sectionBoxStep3 QPushButton#btnBrowse:hover {
    background-color: @S3_BTN_BROWSE_HOVER_BG@;
    border-color: @S3_BTN_BROWSE_HOVER_BORDER@;
    color: @S3_BTN_BROWSE_HOVER_TEXT@;
}

QScrollArea#settingsScroll {
    background: transparent;
    border: none;
}

QScrollArea#settingsScroll > QWidget > QWidget {
    background: transparent;
}

QScrollArea#settingsScroll QScrollBar:vertical {
    background: transparent;
    width: 10px;
    margin: 4px 0 4px 2px;
    border: none;
}

QScrollArea#settingsScroll QScrollBar::handle:vertical {
    background: @BORDER@;
    border-radius: 5px;
    min-height: 40px;
}

QScrollArea#settingsScroll QScrollBar::handle:vertical:hover {
    background: @FG_MUTED@;
}

QScrollArea#settingsScroll QScrollBar::add-line:vertical,
QScrollArea#settingsScroll QScrollBar::sub-line:vertical {
    height: 0;
    width: 0;
    background: none;
    border: none;
}

QScrollArea#settingsScroll QScrollBar::add-page:vertical,
QScrollArea#settingsScroll QScrollBar::sub-page:vertical {
    background: none;
}

QFrame#previewPanel {
    background-color: @BG_PANEL@;
    border: 1px solid @BORDER@;
    border-radius: 8px;
}

QCheckBox#previewToggle {
    font-weight: 600;
    color: @FG_TEXT@;
}

QLabel#previewHint {
    font-size: 11px;
    color: @FG_MUTED@;
}

QFrame#actionFooterBar {
    background-color: @BG_PANEL@;
    border: 1px solid @BORDER@;
    border-radius: 8px;
}

QWidget#menuStrip {
    background-color: @BG_PANEL@;
    border-bottom: 1px solid @BORDER@;
}

QLabel#menuPresetLabel {
    color: @FG_TEXT@;
    font-weight: 600;
    padding-left: 8px;
}

QComboBox#retailPresetCombo {
    min-width: 200px;
}

QWidget#menuStrip QMenuBar {
    background: transparent;
    border: none;
}

QMenuBar {
    background-color: @BG_PANEL@;
    border-bottom: 1px solid @BORDER@;
    color: @FG_TEXT@;
    min-height: 32px;
}

QMenuBar::item:selected {
    background-color: @BG_HOVER@;
    color: @FG_ACCENT@;
}

QMenu {
    background-color: @BG_PANEL@;
    border: 1px solid @BORDER@;
    padding: 4px;
    color: @FG_TEXT@;
}

QMenu::item:selected {
    background-color: @BG_HOVER@;
    color: @FG_ACCENT@;
}

QPushButton {
    background-color: @BG_BUTTON@;
    border: 1px solid @BORDER@;
    border-radius: 4px;
    padding: 0 12px;
    min-height: 28px;
    max-height: 28px;
    color: @FG_TEXT@;
    font-weight: 500;
    font-size: 12px;
}

QPushButton:hover {
    background-color: @BG_HOVER@;
    border-color: @BORDER_FOCUS@;
    color: @FG_ACCENT@;
}

QPushButton#toolBtn {
    background-color: @BG_BUTTON@;
    border: 1px solid @BORDER@;
    padding: 0 6px;
    font-size: 12px;
    min-width: 0;
}

QPushButton#toolBtn:hover {
    background-color: @ACCENT@;
    border-color: @ACCENT@;
    color: #ffffff;
}

QPushButton#btnSecondary {
    background-color: @BG_BUTTON@;
    border: 1px solid @BORDER@;
    min-width: 72px;
}

QPushButton#footerPrimary,
QPushButton#footerSecondary {
    min-height: 32px;
    max-height: 32px;
    min-width: 108px;
    padding: 0 16px;
    font-size: 13px;
    border-radius: 4px;
}

QPushButton#footerPrimary {
    background-color: @ACCENT@;
    color: #ffffff;
    border: 1px solid @ACCENT@;
    font-weight: 700;
}

QPushButton#footerPrimary:hover {
    background-color: @ACCENT_HOVER@;
    border-color: @ACCENT_HOVER@;
}

QPushButton#footerPrimary:disabled {
    background-color: @BG_HOVER@;
    color: @FG_MUTED@;
    border-color: @BORDER@;
}

QPushButton#footerSecondary {
    background-color: @BG_BUTTON@;
    color: @FG_TEXT@;
    border: 1px solid @BORDER@;
    font-weight: 600;
}

QPushButton#footerSecondary:hover {
    background-color: @BG_HOVER@;
    border-color: @BORDER_FOCUS@;
    color: @FG_ACCENT@;
}

QPushButton#footerConvert {
    min-height: 36px;
    max-height: 36px;
    min-width: 132px;
    padding: 0 18px;
    font-size: 13px;
    border-radius: 6px;
    background-color: #16a34a;
    color: #ffffff;
    border: 1px solid #15803d;
    font-weight: 700;
}

QPushButton#footerConvert:hover {
    background-color: #15803d;
    border-color: #166534;
}

QPushButton#footerConvert:disabled {
    background-color: @BG_HOVER@;
    color: @FG_MUTED@;
    border-color: @BORDER@;
}

QPushButton#footerClose {
    min-height: 36px;
    max-height: 36px;
    min-width: 112px;
    padding: 0 16px;
    font-size: 13px;
    border-radius: 6px;
    background-color: @FOOTER_CLOSE_BG@;
    color: #ffffff;
    border: 1px solid @FOOTER_CLOSE_BORDER@;
    font-weight: 600;
}

QPushButton#footerClose:hover {
    background-color: @FOOTER_CLOSE_HOVER@;
    border-color: @FOOTER_CLOSE_BORDER@;
    color: #ffffff;
}

QPushButton#primaryBtn {
    background-color: @ACCENT@;
    color: #ffffff;
    border: 1px solid @ACCENT@;
    font-weight: 700;
    font-size: 13px;
    min-height: 32px;
    max-height: 32px;
    min-width: 100px;
    border-radius: 4px;
}

QPushButton#primaryBtn:hover {
    background-color: @ACCENT_HOVER@;
    border-color: @ACCENT_HOVER@;
}

QPushButton#primaryBtn:disabled {
    background-color: @BG_HOVER@;
    color: @FG_MUTED@;
    border-color: @BORDER@;
}

QPushButton#themeToggle {
    background-color: @BG_HOVER@;
    border: 1px solid @BORDER_FOCUS@;
    color: @FG_ACCENT@;
    font-weight: 600;
    border-radius: 18px;
    padding: 0 16px;
}

QWidget#themeToggleWidget {
    background: transparent;
    min-width: 72px;
    max-width: 72px;
    min-height: 32px;
    max-height: 32px;
    margin: 4px 12px 0 0;
}

QTreeWidget#inputList {
    background-color: @BG_INPUT@;
    alternate-background-color: @BG_PANEL_ALT@;
    border: 1px solid @BORDER@;
    border-radius: 6px;
    color: @FG_TEXT@;
    outline: none;
    padding: 2px;
}

QTreeWidget#inputList QHeaderView::section {
    border-right: 1px solid @SEP@;
}

QTreeWidget#inputList::item {
    padding: 4px 8px;
    min-height: 24px;
    border-bottom: 1px solid @SEP@;
}

QTreeWidget#inputList::item:selected {
    background-color: @ACCENT@;
    color: #ffffff;
}

QTreeWidget#inputList::item:hover:!selected {
    background-color: @BG_HOVER@;
}

QHeaderView::section {
    background-color: @BG_PANEL_ALT@;
    color: @FG_MUTED@;
    padding: 8px 10px;
    border: none;
    border-bottom: 1px solid @BORDER@;
    font-weight: 700;
}

QComboBox {
    background-color: @BG_INPUT@;
    border: 1px solid @COMBO_BORDER@;
    border-radius: 4px;
    padding: 2px 28px 2px 8px;
    min-height: 24px;
    max-height: 30px;
    color: @FG_TEXT@;
    selection-background-color: @ACCENT@;
    selection-color: #ffffff;
}

QLineEdit, QSpinBox {
    background-color: @BG_INPUT@;
    border: 1px solid @BORDER@;
    border-radius: 4px;
    padding: 2px 8px;
    min-height: 28px;
    max-height: 28px;
    color: @FG_TEXT@;
    selection-background-color: @ACCENT@;
    selection-color: #ffffff;
    qproperty-alignment: 'AlignLeft|AlignVCenter';
}

QLineEdit#outputDirEdit {
    font-size: 10px;
    min-height: 26px;
    max-height: 26px;
}

QComboBox:hover {
    border-color: @BORDER_FOCUS@;
    background-color: @BG_HOVER@;
}

QLineEdit:hover, QSpinBox:hover {
    border-color: @BORDER_FOCUS@;
}

QComboBox:focus {
    border: 1px solid @BORDER_FOCUS@;
}

QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: center right;
    width: 26px;
    border-left: 1px solid @COMBO_BORDER@;
    border-top-right-radius: 3px;
    border-bottom-right-radius: 3px;
    background: @BG_HOVER@;
}

QComboBox::drop-down:hover {
    background: @BG_PANEL_ALT@;
}

QComboBox::down-arrow {
    image: url(@COMBO_ARROW@);
    width: 12px;
    height: 12px;
}

QComboBox QAbstractItemView {
    background-color: @BG_PANEL@;
    color: @FG_TEXT@;
    border: 1px solid @BORDER@;
    selection-background-color: @ACCENT@;
    selection-color: #ffffff;
    outline: none;
}

QComboBox QAbstractItemView::item {
    min-height: 28px;
    padding: 4px 10px;
}

QComboBox QAbstractItemView::item:selected {
    background-color: @ACCENT@;
    color: #ffffff;
}

QListWidget {
    background-color: @BG_INPUT@;
    border: 1px solid @BORDER@;
    border-radius: 6px;
    color: @FG_TEXT@;
}

QSlider::groove:horizontal {
    height: 4px;
    background: @BORDER@;
    border-radius: 2px;
}

QSlider::handle:horizontal {
    width: 12px;
    height: 12px;
    margin: -4px 0;
    background: @ACCENT@;
    border: 2px solid @BG_PANEL@;
    border-radius: 6px;
}

QSlider::sub-page:horizontal {
    background: @ACCENT@;
    border-radius: 3px;
}

QProgressBar {
    border: 1px solid @BORDER@;
    border-radius: 4px;
    background: @BG_PANEL_ALT@;
    min-height: 12px;
    max-height: 20px;
    color: @FG_MUTED@;
    text-align: center;
}

QProgressBar#mainProgress,
QProgressBar#resultsProgress {
    background: @BG_INPUT@;
}

QLabel#progressStatus {
    color: @FG_TEXT@;
    font-weight: 600;
    background: transparent;
    padding: 2px 0;
}

QFrame#sectionDivider, QFrame#hSeparator {
    background-color: @SEP@;
    color: @SEP@;
    max-height: 1px;
    border: none;
}

QFrame#vSeparator {
    background-color: @SEP@;
    color: @SEP@;
    max-width: 1px;
    min-width: 1px;
    border: none;
}

QProgressBar::chunk {
    background-color: @ACCENT@;
    border-radius: 3px;
}

QTabWidget::pane {
    border: none;
    background: transparent;
}

QTabBar::tab {
    background: transparent;
    border-bottom: 2px solid transparent;
    padding: 6px 14px;
    color: @FG_MUTED@;
    font-weight: 600;
}

QTabBar::tab:selected {
    color: @FG_ACCENT@;
    border-bottom: 2px solid @ACCENT@;
}

QCheckBox {
    spacing: 6px;
    color: @FG_TEXT@;
    min-height: 22px;
    background: transparent;
}

QCheckBox::indicator {
    width: 18px;
    height: 18px;
    border-radius: 4px;
    border: 2px solid @BORDER_FOCUS@;
    background: @BG_INPUT@;
}

QCheckBox::indicator:checked {
    background: @ACCENT@;
    border-color: @ACCENT@;
    image: url(@CHECK_ICON@);
}

QCheckBox::indicator:disabled {
    border-color: @BORDER@;
    background: @BG_PANEL_ALT@;
}

QCheckBox:disabled {
    color: @FG_MUTED@;
    background: transparent;
}

QFrame#moreOptions {
    background-color: @BG_PANEL_ALT@;
    border: 1px solid @BORDER@;
    border-radius: 6px;
}

QCheckBox#moreToggle {
    font-weight: 600;
    color: @FG_TEXT@;
    padding: 4px 0;
}

QLabel#previewBox {
    border: 1px solid @BORDER@;
    border-radius: 8px;
    background-color: @BG_INPUT@;
    min-width: 112px;
    min-height: 112px;
    max-width: 112px;
    max-height: 112px;
}

QStatusBar {
    background: @BG_PANEL@;
    border-top: 1px solid @BORDER@;
    color: @FG_MUTED@;
}

QSplitter::handle {
    background: @SEP@;
    width: 1px;
    margin: 6px 3px;
}

QSplitter::handle:hover {
    background: @BORDER@;
}

QDialog#appDialog {
    background-color: @BG_PANEL@;
    color: @FG_TEXT@;
}

QDialog#appDialog QLabel {
    color: @FG_TEXT@;
    background: transparent;
}

QTabWidget#dialogTabs::pane {
    border: 1px solid @BORDER@;
    border-radius: 6px;
    background: @BG_PANEL_ALT@;
    padding: 8px;
}

QTabWidget#dialogTabs QTabBar::tab {
    color: @FG_MUTED@;
    padding: 6px 14px;
}

QTabWidget#dialogTabs QTabBar::tab:selected {
    color: @FG_ACCENT@;
    border-bottom: 2px solid @ACCENT@;
}

QTabWidget#dialogTabs QTabBar::tab:last {
    border-left: 1px solid @SEP@;
    margin-left: 8px;
    padding-left: 14px;
}

QGroupBox#moreOptions {
    border: 1px solid @BORDER@;
    border-radius: 6px;
    margin-top: 8px;
    padding-top: 8px;
    font-weight: 600;
    color: @FG_TEXT@;
    background-color: @BG_PANEL_ALT@;
}

QAbstractItemView {
    background-color: @BG_INPUT@;
    color: @FG_TEXT@;
    border: 1px solid @BORDER@;
    selection-background-color: @ACCENT@;
    selection-color: #ffffff;
    outline: none;
}

QListView#formatMultiList::item {
    padding: 6px 10px;
    min-height: 24px;
}

QListView#formatMultiList::item:hover:!selected {
    background-color: @BG_HOVER@;
}

QComboBox#formatMultiCombo {
    min-height: 24px;
    max-height: 30px;
    border: 1px solid @COMBO_BORDER@;
}

QComboBox#formatMultiCombo::drop-down {
    width: 26px;
    border-left: 1px solid @COMBO_BORDER@;
    background: @BG_HOVER@;
}

QComboBox#formatMultiCombo::down-arrow {
    image: url(@COMBO_ARROW@);
    width: 12px;
    height: 12px;
}

QComboBox#formatMultiCombo QLineEdit {
    background: transparent;
    color: @FG_TEXT@;
    border: none;
    padding: 4px 8px;
    qproperty-alignment: 'AlignLeft|AlignVCenter';
}

QTableWidget#resultsTable {
    background-color: @BG_INPUT@;
    color: @FG_TEXT@;
    border: 1px solid @BORDER@;
    gridline-color: @SEP@;
    alternate-background-color: @BG_PANEL_ALT@;
}

QTableWidget#resultsTable::item {
    padding: 5px 8px;
    border-bottom: 1px solid @SEP@;
    border-right: 1px solid @SEP@;
}

QTableWidget#resultsTable::item:selected {
    background-color: @BG_HOVER@;
    color: @FG_TEXT@;
}

QTableWidget#resultsTable QHeaderView::section {
    background-color: @BG_PANEL_ALT@;
    color: @FG_TEXT@;
    padding: 6px 8px;
    border: none;
    border-bottom: 1px solid @SEP@;
    border-right: 1px solid @SEP@;
    font-weight: 600;
}

QLabel#mattePreview {
    border: 1px solid @BORDER@;
    border-radius: 4px;
}

QPushButton#btnBrowse {
    min-width: 100px;
    padding: 0 12px;
}

QPushButton#btnUpdatePath {
    background-color: @ACCENT@;
    color: #ffffff;
    border: 1px solid @ACCENT@;
    font-weight: 700;
    font-size: 13px;
    min-height: 32px;
    max-height: 32px;
    min-width: 100px;
    padding: 0 12px;
    border-radius: 4px;
}

QPushButton#btnUpdatePath:hover {
    background-color: @ACCENT_HOVER@;
    border-color: @ACCENT_HOVER@;
}

QPushButton#btnUpdatePath:disabled {
    background-color: @BG_PANEL_ALT@;
    color: @FG_MUTED@;
    border-color: @BORDER@;
    font-weight: 600;
}

QComboBox:disabled, QLineEdit:disabled, QSpinBox:disabled {
    color: @FG_MUTED@;
    background-color: @BG_PANEL_ALT@;
    border-color: @BORDER@;
}

QPushButton:disabled {
    color: @FG_MUTED@;
    background-color: @BG_PANEL_ALT@;
    border-color: @BORDER@;
}

QMessageBox {
    background-color: @BG_PANEL@;
    color: @FG_TEXT@;
    border: 1px solid @BORDER@;
    border-radius: 8px;
}

QMessageBox QLabel {
    color: @FG_TEXT@;
    background: transparent;
    font-size: 13px;
    min-width: 320px;
    padding: 8px 4px;
}

QMessageBox QPushButton {
    min-width: 88px;
    min-height: 36px;
    max-height: 36px;
    padding: 0 14px;
    font-size: 13px;
    font-weight: 600;
    margin-left: 8px;
}

QMessageBox QPushButton#primaryBtn {
    background-color: @ACCENT@;
    color: #ffffff;
    border: 1px solid @ACCENT@;
}

QMessageBox QPushButton#btnSecondary {
    background-color: @BG_BUTTON@;
    color: @FG_TEXT@;
    border: 1px solid @BORDER@;
    min-height: 36px;
    max-height: 36px;
}

/* —— Overlay konwersji (per plik) —— */
QWidget#conversionOverlay {
    background-color: @OVERLAY_SCRIM@;
}

QFrame#conversionOverlayPanel {
    background-color: @BG_PANEL@;
    border: none;
    border-radius: 10px;
}

QLabel#conversionOverlayTime {
    color: @FG_MUTED@;
    font-size: 11px;
    font-weight: 600;
}

QPushButton#overlayAbortBtn {
    background: transparent;
    color: @OVERLAY_ABORT_COLOR@;
    border: 1px solid @OVERLAY_ABORT_BORDER@;
    border-radius: 6px;
    font-size: 14px;
    font-weight: 700;
    padding: 0;
}

QPushButton#overlayAbortBtn:hover {
    background: @OVERLAY_ABORT_HOVER_BG@;
    border-color: @OVERLAY_ABORT_COLOR@;
    color: @OVERLAY_ABORT_COLOR@;
}

QPushButton#overlayAbortBtn:pressed {
    background: @OVERLAY_ABORT_PRESSED@;
}

QLabel#conversionOverlayHint {
    color: @OVERLAY_HINT@;
    font-size: 11px;
    line-height: 1.4;
    padding: 2px 0 4px 0;
    background: transparent;
}

QLabel#conversionOverlayTitle {
    font-size: 15px;
    font-weight: 700;
    color: @FG_TEXT@;
}

QLabel#conversionOverlaySummary {
    color: @FG_MUTED@;
    font-size: 12px;
}

QScrollArea#conversionOverlayScroll {
    background: transparent;
}

QFrame#fileProgressCard {
    background: @BG_PANEL_ALT@;
    border: none;
    border-radius: 8px;
}

QFrame#fileProgressCard[status="active"] {
    background: @BG_PANEL_ALT@;
}

QFrame#fileProgressCard[status="done"] {
    background: @BG_PANEL_ALT@;
}

QFrame#fileProgressCard[status="error"] {
    background: @BG_PANEL_ALT@;
}

QLabel#fileProgressExt {
    background: @BG_INPUT@;
    border: 1px solid @BORDER@;
    border-radius: 6px;
    font-size: 10px;
    font-weight: 700;
    color: @FG_ACCENT@;
}

QLabel#fileProgressName {
    font-weight: 600;
    color: @FG_TEXT@;
}

QLabel#fileProgressMeta {
    color: @FG_MUTED@;
    font-size: 11px;
}

QLabel#fileProgressPct {
    color: @FG_MUTED@;
    font-size: 11px;
    font-weight: 600;
}

QProgressBar#fileProgressBar,
QProgressBar#conversionOverlayOverall {
    background: @BG_INPUT@;
    border: none;
    border-radius: 4px;
}

QProgressBar#fileProgressBar::chunk,
QProgressBar#conversionOverlayOverall::chunk {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 @ACCENT@, stop:1 #7c3aed);
    border-radius: 4px;
}
