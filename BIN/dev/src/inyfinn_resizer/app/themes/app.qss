/* Inyfinn Photo Resizer — wspólna struktura UI (identyczna w obu motywach) */

QMainWindow {
    background-color: @BG_WINDOW@;
    color: @FG_TEXT@;
    font-family: "Segoe UI", system-ui, sans-serif;
    font-size: 13px;
}

QWidget#centralRoot, QWidget#settingsBody, QWidget#formatSelector {
    background-color: transparent;
    color: @FG_TEXT@;
}

QLabel {
    background-color: transparent;
    color: @FG_TEXT@;
}

QLabel#appTitle {
    font-size: 16px;
    font-weight: 600;
    color: @FG_TITLE@;
}

QLabel#versionBadge {
    font-size: 11px;
    font-weight: 600;
    color: @FG_ACCENT@;
    background: transparent;
}

QLabel#panelTitle {
    font-size: 13px;
    font-weight: 700;
    color: @FG_TITLE@;
    padding: 0;
    margin: 0;
    background: transparent;
}

QLabel#sectionTitle {
    font-size: 12px;
    font-weight: 700;
    color: @FG_MUTED@;
    background: transparent;
}

QLabel#fieldLabel {
    font-size: 12px;
    font-weight: 600;
    color: @FG_TEXT@;
    background: transparent;
}

QLabel#advancedSummary {
    font-size: 11px;
    color: @FG_MUTED@;
    padding: 0;
    background: transparent;
    border: none;
}

QLabel#appFooter {
    font-size: 11px;
    font-weight: 600;
    color: @FG_MUTED@;
    padding: 0 4px;
    background: transparent;
}

QDialog#helpGuideDialog {
    background-color: @BG_WINDOW@;
    color: @FG_TEXT@;
}

QLabel#helpGuideIntro {
    font-size: 13px;
    color: @FG_TEXT@;
    background: transparent;
}

QLabel#helpGuideItem {
    font-size: 13px;
    line-height: 1.45;
    color: @FG_TEXT@;
    padding: 2px 0;
    background: transparent;
}

QWidget#helpGuideBody {
    background: transparent;
}

QScrollArea#helpGuideScroll {
    background: transparent;
    border: none;
}

QLabel#helpGuideTitle {
    font-size: 15px;
    font-weight: 700;
    color: @FG_TITLE@;
}

QLabel#helpGuideVersion {
    font-size: 11px;
    font-weight: 600;
    color: @FG_ACCENT@;
}

QLabel#helpGuideContent {
    font-size: 13px;
    color: @FG_TEXT@;
    padding: 4px 2px;
}

QWidget#fieldGroup {
    background: transparent;
}

QLabel#formLabel, QLabel#formLabelInline {
    color: @FG_MUTED@;
    font-weight: 600;
    background: transparent;
}

QLabel#hintLabel, QLabel#dropHint {
    color: @FG_MUTED@;
    font-size: 12px;
}

QLabel#queueCount {
    font-size: 14px;
    font-weight: 700;
    color: @FG_ACCENT@;
}

QLabel#qualityValue {
    font-weight: 700;
    color: @FG_ACCENT@;
}

QLabel#previewMeta {
    color: @FG_MUTED@;
    font-size: 12px;
}

QFrame#panel, QFrame#dropPanel {
    background-color: @BG_PANEL@;
    border: 1px solid @BORDER@;
    border-radius: 8px;
}

QFrame#dropPanel {
    background-color: @BG_PANEL_ALT@;
}

QFrame#sectionBox {
    background-color: @BG_PANEL_ALT@;
    border: 1px solid @BORDER@;
    border-radius: 6px;
}

QScrollArea#settingsScroll {
    background: transparent;
    border: none;
}

QScrollArea#settingsScroll > QWidget > QWidget {
    background: transparent;
}

QWidget#menuStrip {
    background-color: @BG_PANEL@;
    border-bottom: 1px solid @BORDER@;
}

QWidget#menuStrip QMenuBar {
    background: transparent;
    border: none;
}

QMenuBar {
    background-color: @BG_PANEL@;
    border-bottom: 1px solid @BORDER@;
    color: @FG_TEXT@;
    min-height: 32px;
}

QMenuBar::item:selected {
    background-color: @BG_HOVER@;
    color: @FG_ACCENT@;
}

QMenu {
    background-color: @BG_PANEL@;
    border: 1px solid @BORDER@;
    padding: 4px;
    color: @FG_TEXT@;
}

QMenu::item:selected {
    background-color: @BG_HOVER@;
    color: @FG_ACCENT@;
}

QPushButton {
    background-color: @BG_BUTTON@;
    border: 1px solid @BORDER@;
    border-radius: 4px;
    padding: 0 12px;
    min-height: 28px;
    max-height: 28px;
    color: @FG_TEXT@;
    font-weight: 500;
    font-size: 12px;
}

QPushButton:hover {
    background-color: @BG_HOVER@;
    border-color: @BORDER_FOCUS@;
    color: @FG_ACCENT@;
}

QPushButton#toolBtn {
    background-color: @BG_BUTTON@;
    border: 1px solid @BORDER@;
    padding: 0 6px;
    font-size: 12px;
    min-width: 0;
}

QPushButton#toolBtn:hover {
    background-color: @ACCENT@;
    border-color: @ACCENT@;
    color: #ffffff;
}

QPushButton#btnSecondary {
    background-color: @BG_BUTTON@;
    border: 1px solid @BORDER@;
    min-width: 72px;
}

QPushButton#footerPrimary,
QPushButton#footerSecondary {
    min-height: 32px;
    max-height: 32px;
    min-width: 108px;
    padding: 0 16px;
    font-size: 13px;
    border-radius: 4px;
}

QPushButton#footerPrimary {
    background-color: @ACCENT@;
    color: #ffffff;
    border: 1px solid @ACCENT@;
    font-weight: 700;
}

QPushButton#footerPrimary:hover {
    background-color: @ACCENT_HOVER@;
    border-color: @ACCENT_HOVER@;
}

QPushButton#footerPrimary:disabled {
    background-color: @BG_HOVER@;
    color: @FG_MUTED@;
    border-color: @BORDER@;
}

QPushButton#footerSecondary {
    background-color: @BG_BUTTON@;
    color: @FG_TEXT@;
    border: 1px solid @BORDER@;
    font-weight: 600;
}

QPushButton#footerSecondary:hover {
    background-color: @BG_HOVER@;
    border-color: @BORDER_FOCUS@;
    color: @FG_ACCENT@;
}

QPushButton#primaryBtn {
    background-color: @ACCENT@;
    color: #ffffff;
    border: 1px solid @ACCENT@;
    font-weight: 700;
    font-size: 13px;
    min-height: 32px;
    max-height: 32px;
    min-width: 100px;
    border-radius: 4px;
}

QPushButton#primaryBtn:hover {
    background-color: @ACCENT_HOVER@;
    border-color: @ACCENT_HOVER@;
}

QPushButton#primaryBtn:disabled {
    background-color: @BG_HOVER@;
    color: @FG_MUTED@;
    border-color: @BORDER@;
}

QPushButton#themeToggle {
    background-color: @BG_HOVER@;
    border: 1px solid @BORDER_FOCUS@;
    color: @FG_ACCENT@;
    font-weight: 600;
    border-radius: 18px;
    padding: 0 16px;
}

QWidget#themeToggleWidget {
    background: transparent;
    min-width: 72px;
    max-width: 72px;
    min-height: 32px;
    max-height: 32px;
    margin: 4px 12px 0 0;
}

QTreeWidget#inputList {
    background-color: @BG_INPUT@;
    alternate-background-color: @BG_PANEL_ALT@;
    border: 1px solid @BORDER@;
    border-radius: 6px;
    color: @FG_TEXT@;
    outline: none;
    padding: 2px;
}

QTreeWidget#inputList QHeaderView::section {
    border-right: 1px solid @SEP@;
}

QTreeWidget#inputList::item {
    padding: 4px 8px;
    min-height: 24px;
    border-bottom: 1px solid @SEP@;
}

QTreeWidget#inputList::item:selected {
    background-color: @ACCENT@;
    color: #ffffff;
}

QTreeWidget#inputList::item:hover:!selected {
    background-color: @BG_HOVER@;
}

QHeaderView::section {
    background-color: @BG_PANEL_ALT@;
    color: @FG_MUTED@;
    padding: 8px 10px;
    border: none;
    border-bottom: 1px solid @BORDER@;
    font-weight: 700;
}

QComboBox {
    background-color: @BG_INPUT@;
    border: 1px solid @COMBO_BORDER@;
    border-radius: 4px;
    padding: 2px 28px 2px 8px;
    min-height: 28px;
    max-height: 28px;
    color: @FG_TEXT@;
    selection-background-color: @ACCENT@;
    selection-color: #ffffff;
}

QLineEdit, QSpinBox {
    background-color: @BG_INPUT@;
    border: 1px solid @BORDER@;
    border-radius: 4px;
    padding: 2px 8px;
    min-height: 28px;
    max-height: 28px;
    color: @FG_TEXT@;
    selection-background-color: @ACCENT@;
    selection-color: #ffffff;
    qproperty-alignment: 'AlignLeft|AlignVCenter';
}

QLineEdit#outputDirEdit {
    font-size: 10px;
    min-height: 26px;
    max-height: 26px;
}

QComboBox:hover {
    border-color: @BORDER_FOCUS@;
    background-color: @BG_HOVER@;
}

QLineEdit:hover, QSpinBox:hover {
    border-color: @BORDER_FOCUS@;
}

QComboBox:focus {
    border: 1px solid @BORDER_FOCUS@;
}

QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: center right;
    width: 26px;
    border-left: 1px solid @COMBO_BORDER@;
    border-top-right-radius: 3px;
    border-bottom-right-radius: 3px;
    background: @BG_HOVER@;
}

QComboBox::drop-down:hover {
    background: @BG_PANEL_ALT@;
}

QComboBox::down-arrow {
    image: url(@COMBO_ARROW@);
    width: 12px;
    height: 12px;
}

QComboBox QAbstractItemView {
    background-color: @BG_PANEL@;
    color: @FG_TEXT@;
    border: 1px solid @BORDER@;
    selection-background-color: @ACCENT@;
    selection-color: #ffffff;
    outline: none;
}

QComboBox QAbstractItemView::item {
    min-height: 28px;
    padding: 4px 10px;
}

QComboBox QAbstractItemView::item:selected {
    background-color: @ACCENT@;
    color: #ffffff;
}

QListWidget {
    background-color: @BG_INPUT@;
    border: 1px solid @BORDER@;
    border-radius: 6px;
    color: @FG_TEXT@;
}

QSlider::groove:horizontal {
    height: 6px;
    background: @BORDER@;
    border-radius: 3px;
}

QSlider::handle:horizontal {
    width: 16px;
    height: 16px;
    margin: -5px 0;
    background: @ACCENT@;
    border: 2px solid @BG_PANEL@;
    border-radius: 8px;
}

QSlider::sub-page:horizontal {
    background: @ACCENT@;
    border-radius: 3px;
}

QProgressBar {
    border: 1px solid @BORDER@;
    border-radius: 4px;
    background: @BG_PANEL_ALT@;
    min-height: 12px;
    max-height: 20px;
    color: @FG_MUTED@;
    text-align: center;
}

QProgressBar#mainProgress,
QProgressBar#resultsProgress {
    background: @BG_INPUT@;
}

QLabel#progressStatus {
    color: @FG_TEXT@;
    font-weight: 600;
    background: transparent;
    padding: 2px 0;
}

QFrame#sectionDivider, QFrame#hSeparator {
    background-color: @SEP@;
    color: @SEP@;
    max-height: 1px;
    border: none;
}

QFrame#vSeparator {
    background-color: @SEP@;
    color: @SEP@;
    max-width: 1px;
    min-width: 1px;
    border: none;
}

QProgressBar::chunk {
    background-color: @ACCENT@;
    border-radius: 3px;
}

QTabWidget::pane {
    border: none;
    background: transparent;
}

QTabBar::tab {
    background: transparent;
    border-bottom: 2px solid transparent;
    padding: 6px 14px;
    color: @FG_MUTED@;
    font-weight: 600;
}

QTabBar::tab:selected {
    color: @FG_ACCENT@;
    border-bottom: 2px solid @ACCENT@;
}

QCheckBox {
    spacing: 6px;
    color: @FG_TEXT@;
    min-height: 22px;
    background: transparent;
}

QCheckBox::indicator {
    width: 18px;
    height: 18px;
    border-radius: 4px;
    border: 2px solid @BORDER_FOCUS@;
    background: @BG_INPUT@;
}

QCheckBox::indicator:checked {
    background: @ACCENT@;
    border-color: @ACCENT@;
    image: url(@CHECK_ICON@);
}

QCheckBox::indicator:disabled {
    border-color: @BORDER@;
    background: @BG_PANEL_ALT@;
}

QCheckBox:disabled {
    color: @FG_MUTED@;
    background: transparent;
}

QFrame#moreOptions {
    background-color: @BG_PANEL_ALT@;
    border: 1px solid @BORDER@;
    border-radius: 6px;
}

QCheckBox#moreToggle {
    font-weight: 600;
    color: @FG_TEXT@;
    padding: 4px 0;
}

QLabel#previewBox {
    border: 1px solid @BORDER@;
    border-radius: 6px;
    background-color: @BG_INPUT@;
}

QStatusBar {
    background: @BG_PANEL@;
    border-top: 1px solid @BORDER@;
    color: @FG_MUTED@;
}

QSplitter::handle {
    background: @SEP@;
    width: 1px;
    margin: 6px 3px;
}

QSplitter::handle:hover {
    background: @BORDER@;
}

QDialog#appDialog {
    background-color: @BG_PANEL@;
    color: @FG_TEXT@;
}

QDialog#appDialog QLabel {
    color: @FG_TEXT@;
    background: transparent;
}

QTabWidget#dialogTabs::pane {
    border: 1px solid @BORDER@;
    border-radius: 6px;
    background: @BG_PANEL_ALT@;
    padding: 8px;
}

QTabWidget#dialogTabs QTabBar::tab {
    color: @FG_MUTED@;
    padding: 6px 14px;
}

QTabWidget#dialogTabs QTabBar::tab:selected {
    color: @FG_ACCENT@;
    border-bottom: 2px solid @ACCENT@;
}

QTabWidget#dialogTabs QTabBar::tab:last {
    border-left: 1px solid @SEP@;
    margin-left: 8px;
    padding-left: 14px;
}

QGroupBox#moreOptions {
    border: 1px solid @BORDER@;
    border-radius: 6px;
    margin-top: 8px;
    padding-top: 8px;
    font-weight: 600;
    color: @FG_TEXT@;
    background-color: @BG_PANEL_ALT@;
}

QAbstractItemView {
    background-color: @BG_INPUT@;
    color: @FG_TEXT@;
    border: 1px solid @BORDER@;
    selection-background-color: @ACCENT@;
    selection-color: #ffffff;
    outline: none;
}

QListView#formatMultiList::item {
    padding: 6px 10px;
    min-height: 24px;
}

QListView#formatMultiList::item:hover {
    background-color: @BG_HOVER@;
}

QComboBox#formatMultiCombo {
    min-height: 28px;
    max-height: 28px;
    border: 1px solid @COMBO_BORDER@;
}

QComboBox#formatMultiCombo::drop-down {
    width: 26px;
    border-left: 1px solid @COMBO_BORDER@;
    background: @BG_HOVER@;
}

QComboBox#formatMultiCombo::down-arrow {
    image: url(@COMBO_ARROW@);
    width: 12px;
    height: 12px;
}

QComboBox#formatMultiCombo QLineEdit {
    background: transparent;
    color: @FG_TEXT@;
    border: none;
    padding: 4px 8px;
    qproperty-alignment: 'AlignLeft|AlignVCenter';
}

QTableWidget#resultsTable {
    background-color: @BG_INPUT@;
    color: @FG_TEXT@;
    border: 1px solid @BORDER@;
    gridline-color: @SEP@;
    alternate-background-color: @BG_PANEL_ALT@;
}

QTableWidget#resultsTable::item {
    padding: 5px 8px;
    border-bottom: 1px solid @SEP@;
    border-right: 1px solid @SEP@;
}

QTableWidget#resultsTable::item:selected {
    background-color: @BG_HOVER@;
    color: @FG_TEXT@;
}

QTableWidget#resultsTable QHeaderView::section {
    background-color: @BG_PANEL_ALT@;
    color: @FG_TEXT@;
    padding: 6px 8px;
    border: none;
    border-bottom: 1px solid @SEP@;
    border-right: 1px solid @SEP@;
    font-weight: 600;
}

QLabel#mattePreview {
    border: 1px solid @BORDER@;
    border-radius: 4px;
}

QPushButton#btnBrowse {
    min-width: 100px;
    padding: 0 12px;
}

QComboBox:disabled, QLineEdit:disabled, QSpinBox:disabled {
    color: @FG_MUTED@;
    background-color: @BG_PANEL_ALT@;
    border-color: @BORDER@;
}

QPushButton:disabled {
    color: @FG_MUTED@;
    background-color: @BG_PANEL_ALT@;
    border-color: @BORDER@;
}

QMessageBox {
    background-color: @BG_PANEL@;
    color: @FG_TEXT@;
    border: 1px solid @BORDER@;
    border-radius: 8px;
}

QMessageBox QLabel {
    color: @FG_TEXT@;
    background: transparent;
    font-size: 13px;
    min-width: 320px;
    padding: 8px 4px;
}

QMessageBox QPushButton {
    min-width: 88px;
    min-height: 36px;
    max-height: 36px;
    padding: 0 14px;
    font-size: 13px;
    font-weight: 600;
    margin-left: 8px;
}

QMessageBox QPushButton#primaryBtn {
    background-color: @ACCENT@;
    color: #ffffff;
    border: 1px solid @ACCENT@;
}

QMessageBox QPushButton#btnSecondary {
    background-color: @BG_BUTTON@;
    color: @FG_TEXT@;
    border: 1px solid @BORDER@;
    min-height: 36px;
    max-height: 36px;
}
