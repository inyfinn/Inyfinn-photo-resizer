/* Inyfinn Photo Resizer — ciemny motyw v2 (granat, czytelny kontrast) */

QMainWindow {
    background-color: #0c1220;
    color: #e8edf7;
    font-family: "Segoe UI", system-ui, sans-serif;
    font-size: 13px;
}

QWidget#centralRoot, QWidget#settingsBody, QWidget#formatSelector {
    background-color: transparent;
    color: #e8edf7;
}

QLabel {
    background-color: transparent;
    color: #cbd5e1;
}

QLabel#appTitle {
    font-size: 16px;
    font-weight: 600;
    color: #f1f5f9;
}

QLabel#versionBadge {
    font-size: 11px;
    font-weight: 600;
    color: #a5b4fc;
    background: transparent;
    padding: 0;
}

QLabel#panelTitle {
    font-size: 15px;
    font-weight: 700;
    color: #f8fafc;
    padding: 0;
    background: transparent;
}

QLabel#sectionTitle {
    font-size: 12px;
    font-weight: 700;
    color: #a5b4fc;
    background: transparent;
}

QLabel#formLabel, QLabel#formLabelInline {
    color: #94a3b8;
    font-weight: 600;
    background: transparent;
}

QLabel#hintLabel, QLabel#dropHint {
    color: #94a3b8;
    font-size: 12px;
}

QLabel#queueCount {
    font-size: 14px;
    font-weight: 700;
    color: #a5b4fc;
}

QLabel#qualityValue {
    font-weight: 700;
    color: #c7d2fe;
}

QLabel#previewMeta {
    color: #94a3b8;
    font-size: 12px;
}

/* —— Panele —— */
QFrame#panel {
    background-color: #141e34;
    border: 1px solid #3d5080;
    border-radius: 6px;
}

QFrame#dropPanel {
    background-color: #0a101c;
    border: 1px solid #2a3a62;
    border-radius: 6px;
}

QFrame#sectionBox {
    background-color: #121c32;
    border: 1px solid #3d5080;
    border-radius: 8px;
}

QScrollArea#settingsScroll {
    background: transparent;
    border: none;
}

/* —— Menu —— */
QMenuBar {
    background-color: #10182b;
    border-bottom: 1px solid #3d5080;
    color: #e8edf7;
}

QMenuBar::item:selected {
    background-color: #252f4d;
    color: #c7d2fe;
}

QMenu {
    background-color: #1a2540;
    border: 1px solid #3d5080;
    color: #e8edf7;
}

QMenu::item:selected {
    background-color: #2d3a5c;
    color: #e0e7ff;
}

/* —— Przyciski —— */
QPushButton {
    background-color: #1e2d4a;
    border: 1px solid #4a5f8c;
    border-radius: 4px;
    padding: 6px 14px;
    min-height: 36px;
    color: #f1f5f9;
    font-weight: 500;
}

QPushButton:hover {
    background-color: #2a3d66;
    border-color: #818cf8;
    color: #ffffff;
}

QPushButton#toolBtn {
    background-color: #10182b;
    border: 1px solid #3d5080;
}

QPushButton#toolBtn:hover {
    background-color: #6366f1;
    border-color: #818cf8;
    color: #ffffff;
}

QPushButton#btnSecondary {
    background-color: #152238;
    border: 1px solid #5a6f9a;
    min-width: 88px;
}

QPushButton#primaryBtn {
    background-color: #6366f1;
    color: #ffffff;
    border: 1px solid #818cf8;
    font-weight: 700;
    font-size: 14px;
    min-height: 40px;
    min-width: 120px;
}

QPushButton#primaryBtn:hover {
    background-color: #818cf8;
}

QPushButton#primaryBtn:disabled {
    background-color: #2d3a5c;
    color: #64748b;
    border-color: #3d5080;
}

QPushButton#themeToggle {
    background-color: #252f4d;
    border: 1px solid #818cf8;
    color: #e0e7ff;
    font-weight: 600;
    border-radius: 18px;
}

/* —— Lista (najciemniejsza) —— */
QTreeWidget#inputList {
    background-color: #050810;
    alternate-background-color: #0a101c;
    border: 1px solid #2a3a62;
    border-radius: 6px;
    color: #f1f5f9;
    outline: none;
}

QTreeWidget#inputList::item {
    padding: 6px 8px;
    min-height: 28px;
}

QTreeWidget#inputList::item:selected {
    background-color: #6366f1;
    color: #ffffff;
}

QTreeWidget#inputList::item:hover:!selected {
    background-color: #151d33;
}

QHeaderView::section {
    background-color: #0a101c;
    color: #94a3b8;
    padding: 8px 10px;
    border: none;
    border-bottom: 1px solid #2a3a62;
    font-weight: 700;
}

/* —— Pola —— */
QComboBox, QLineEdit, QSpinBox {
    background-color: #0f1729;
    border: 1px solid #5a6f9a;
    border-radius: 4px;
    padding: 6px 10px;
    min-height: 36px;
    color: #f8fafc;
    selection-background-color: #6366f1;
}

QComboBox:hover, QLineEdit:hover {
    border-color: #818cf8;
}

QComboBox QAbstractItemView {
    background-color: #1a2540;
    border: 1px solid #3d5080;
    color: #f1f5f9;
    selection-background-color: #6366f1;
    outline: none;
}

QComboBox QAbstractItemView::item {
    min-height: 28px;
    padding: 4px 10px;
    color: #f1f5f9;
}

QComboBox QAbstractItemView::item:selected {
    background-color: #6366f1;
    color: #ffffff;
}

QListWidget {
    background-color: #0c1424;
    border: 1px solid #3d5080;
    border-radius: 6px;
    color: #e8edf7;
}

QSlider::groove:horizontal {
    height: 6px;
    background: #2d3a5c;
    border-radius: 3px;
}

QSlider::handle:horizontal {
    width: 16px;
    height: 16px;
    margin: -5px 0;
    background: #818cf8;
    border: 2px solid #1a2540;
    border-radius: 8px;
}

QSlider::sub-page:horizontal {
    background: #6366f1;
    border-radius: 3px;
}

QProgressBar {
    border: 1px solid #3d5080;
    border-radius: 4px;
    background: #2d3a5c;
    min-height: 12px;
    color: #cbd5e1;
}

QProgressBar::chunk {
    background-color: #818cf8;
}

QTabBar::tab {
    background: transparent;
    border-bottom: 2px solid transparent;
    padding: 8px 18px;
    color: #94a3b8;
    font-weight: 600;
}

QTabBar::tab:selected {
    color: #c7d2fe;
    border-bottom: 2px solid #818cf8;
}

QCheckBox {
    spacing: 8px;
    color: #e2e8f0;
    min-height: 26px;
    background: transparent;
}

QCheckBox::indicator {
    width: 18px;
    height: 18px;
    border-radius: 3px;
    border: 2px solid #7c8db5;
    background: #0f1729;
}

QCheckBox::indicator:checked {
    background: #6366f1;
    border-color: #a5b4fc;
    image: url(@CHECK_ICON@);
}

QFrame#moreOptions {
    background-color: #0f1729;
    border: 1px solid #3d5080;
    border-radius: 4px;
}

QCheckBox#moreToggle {
    font-weight: 600;
    color: #e2e8f0;
    padding: 4px 0;
}

QLabel#previewBox {
    border: 1px solid #3d5080;
    border-radius: 6px;
    background-color: #050810;
}

QStatusBar {
    background: #10182b;
    border-top: 1px solid #3d5080;
    color: #94a3b8;
}

QSplitter::handle {
    background: #2d3a5c;
    width: 3px;
    margin: 4px 2px;
    border-radius: 2px;
}

QSplitter::handle:hover {
    background: #818cf8;
}

QDialog#appDialog {
    background-color: #1a2540;
    color: #f1f5f9;
}

QDialog#appDialog QLabel {
    color: #e2e8f0;
    background: transparent;
}

QTabWidget#dialogTabs::pane {
    border: 1px solid #3d5080;
    border-radius: 6px;
    background: #121c32;
    padding: 8px;
}

QTabWidget#dialogTabs QTabBar::tab {
    color: #94a3b8;
    padding: 6px 14px;
}

QTabWidget#dialogTabs QTabBar::tab:selected {
    color: #c7d2fe;
    border-bottom: 2px solid #818cf8;
}

QGroupBox#moreOptions {
    border: 1px solid #3d5080;
    border-radius: 4px;
    margin-top: 8px;
    padding-top: 8px;
    font-weight: 600;
    color: #e2e8f0;
    background-color: #0f1729;
}

QGroupBox#moreOptions::title {
    subcontrol-origin: margin;
    left: 10px;
    padding: 0 6px;
    color: #e2e8f0;
}

QAbstractItemView {
    background-color: #0c1424;
    color: #f8fafc;
    border: 1px solid #4a5f8c;
    selection-background-color: #6366f1;
    selection-color: #ffffff;
    outline: none;
}

QListView#formatMultiList::item {
    padding: 6px 10px;
    min-height: 24px;
}

QListView#formatMultiList::item:hover:!selected {
    background-color: #1e2d4a;
}

QComboBox#formatMultiCombo {
    min-height: 36px;
}

QComboBox#formatMultiCombo QLineEdit {
    background: transparent;
    color: #f8fafc;
    border: none;
    padding: 4px 8px;
}

QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 32px;
    border-left: 1px solid #3d5080;
    background: #152238;
    border-top-right-radius: 4px;
    border-bottom-right-radius: 4px;
}

QComboBox::drop-down:hover {
    background: #6366f1;
}

QLabel#hintLabel {
    color: #94a3b8;
    font-size: 12px;
    background: transparent;
}

QSpinBox {
    background-color: #0c1424;
    border: 1px solid #4a5f8c;
    border-radius: 6px;
    padding: 4px 8px;
    min-height: 32px;
    color: #f8fafc;
}

QTableWidget#resultsTable {
    background-color: #0c1424;
    color: #f1f5f9;
    border: 1px solid #3d5080;
    gridline-color: #2d3a5c;
}

QTableWidget#resultsTable::item {
    padding: 4px 6px;
}

QHeaderView::section {
    background-color: #121c32;
    color: #e2e8f0;
    padding: 6px 8px;
    border: none;
    border-bottom: 1px solid #3d5080;
    font-weight: 600;
}

/* —— QMessageBox (popupy systemowe) —— */
QMessageBox {
    background-color: #1a2540;
    color: #f1f5f9;
    border: 1px solid #5a6f9a;
    border-radius: 8px;
}

QMessageBox QLabel {
    color: #e8edf7;
    background: transparent;
    font-size: 13px;
    min-width: 320px;
    padding: 8px 4px;
}

QMessageBox QPushButton {
    min-width: 88px;
    min-height: 36px;
}

QComboBox:disabled, QLineEdit:disabled, QPushButton:disabled, QCheckBox:disabled {
    color: #64748b;
    background-color: #0f1729;
    border-color: #2d3a5c;
}
